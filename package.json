{
  "name": "esports-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --project-id tbuxtlbtjpoholcflmoy --schema public > types/database.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:clean": "playwright test --project=chromium",
    "test:e2e:workspace": "playwright test --project=workspace-seed --project=dashboard-tests --project=manage-tests --project=workspace-tests --project=integration-tests",
    "test:e2e:admin": "playwright test --project=admin-setup --project=admin-tests",
    "dev:vision": "python scratch/mlbb-vision/server.py",
    "dev:all": "concurrently -n next,vision -c cyan,magenta --kill-others \"npm run dev\" \"npm run dev:vision\""
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.40.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "ws": "^8.21.0"
  }
}
