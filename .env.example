# --- Supabase (server + client) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://tbuxtlbtjpoholcflmoy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_QH_Y-096q0C9bz7TawJh1A_hBwI41DN

# Service-role key — server only, never expose to the browser.
# Get it from: Supabase Dashboard → Project Settings → API
